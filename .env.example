# LLM Provider: "google" (default) or "anthropic"
MCP_AUDITOR_PROVIDER=google

# Model overrides (optional — defaults are set in config.py)
# MCP_AUDITOR_MODEL=gemini-3.1-flash-lite
# MCP_AUDITOR_JUDGE_MODEL=gemini-3.1-pro-preview

# API keys (set the one matching your provider)
# GOOGLE_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# LangSmith (optional — enables tracing when set)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-key-here
# LANGSMITH_PROJECT=mcp-auditor
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com  # set only if your LangSmith workspace is in the EU region
